{
  "permissions": {
    "allow": [
      "Bash(python*)",
      "Bash(git *)",
      "Bash(node *)",
      "Bash(npx *)",
      "Read(*)",
      "Write(context/**)",
      "Write(deliverables/**)",
      "Write(scripts/**)",
      "Write(MASTER_CONTEXT.md)",
      "Write(DELIVERABLE_STATUS.md)",
      "Write(.claude/skills/**)",
      "Edit(context/**)",
      "Edit(deliverables/**)",
      "Edit(MASTER_CONTEXT.md)",
      "Edit(DELIVERABLE_STATUS.md)",
      "Edit(scripts/**)",
      "Edit(projects/**)",
      "Write(projects/**)",
      "Write(audit/**)",
      "Write(GLOSSARY.md)",
      "Write(workbench.config.yaml)",
      "Edit(workbench.config.yaml)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/append_ledger.py"
          }
        ]
      }
    ]
  }
}
