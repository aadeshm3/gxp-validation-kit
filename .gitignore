# Secrets / environment
*.env
.env.*

# Python
__pycache__/
*.pyc

# Node
node_modules/

# OS
.DS_Store
Thumbs.db

# Temp / logs
*.tmp
*.log

# --- Protect against committing real project material ---
# This repo is a template. Users clone it and drop their own SOPs, source files,
# and drafts into the folders below. Those local files must never be committed
# to the shared repo. The folder structure and READMEs are kept; everything a
# user adds is ignored. Remove these rules only if you deliberately want to
# version a project's content in its own private clone.
sops/**
!sops/**/
!sops/**/.gitkeep
!sops/**/README.md

context/**
!context/**/
!context/**/.gitkeep

deliverables/in-progress/**
!deliverables/in-progress/**/
!deliverables/in-progress/**/.gitkeep

# approved/ is intentionally NOT ignored — signed-off deliverables must be versioned

# Generated dashboard (runtime artifact — regenerate with scripts/dashboard.py)
status.html

# Activity ledger (runtime audit log). If your record policy requires retaining
# it in version control, remove this line and commit the file deliberately.
audit/ledger.jsonl

# Local presentation/enablement artifacts — kept on disk, never committed
*.pptx
scripts/make_intro_deck.py
